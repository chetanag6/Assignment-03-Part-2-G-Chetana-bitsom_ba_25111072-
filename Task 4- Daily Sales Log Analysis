# Total revenue per day
print("=== Revenue Per Day ===")
daily_revenue = {}
dates = list(sales_log.keys())
i = 0
while i < len(dates):
    date = dates[i]
    total = 0.0
    j = 0
    orders = sales_log[date]
    while j < len(orders):
        total = total + orders[j]["total"]
        j = j + 1
    daily_revenue[date] = total
    print(date + ": ₹" + str(round(total, 2)))
    i = i + 1
print()

# Best selling day
max_revenue = 0
best_day = ""
i = 0
while i < len(dates):
    date = dates[i]
    if daily_revenue[date] > max_revenue:
        max_revenue = daily_revenue[date]
        best_day = date
    i = i + 1
print("Best selling day:", best_day, "₹" + str(round(max_revenue, 2)))
print()

# Most ordered item
item_count = {}
all_items = []
i = 0
while i < len(dates):
    date = dates[i]
    j = 0
    orders = sales_log[date]
    while j < len(orders):
        k = 0
        items = orders[j]["items"]
        while k < len(items):
            item = items[k]
            if item not in item_count:
                item_count[item] = 0
            item_count[item] = item_count[item] + 1
            k = k + 1
        j = j + 1
    i = i + 1

max_orders = 0
most_ordered = ""
for item in item_count:
    if item_count[item] > max_orders:
        max_orders = item_count[item]
        most_ordered = item
print("Most ordered item:", most_ordered, "(" + str(max_orders) + " orders)")
print()

