# Numbered list of all orders using enumerate
print("=== All Orders ===")
all_orders = []
dates = list(sales_log.keys())
i = 0
while i < len(dates):
    date = dates[i]
    j = 0
    orders = sales_log[date]
    while j < len(orders):
        order = orders[j]
        all_orders.append((date, order))
        j = j + 1
    i = i + 1

order_num = 1
k = 0
while k < len(all_orders):
    date = all_orders[k][0]
    order = all_orders[k][1]
    order_id = order["order_id"]
    total = order["total"]
    items = order["items"]
    items_str = ""
    m = 0
    while m < len(items):
        items_str = items_str + items[m]
        if m < len(items) - 1:
            items_str = items_str + ", "
        m = m + 1
    
    print(str(order_num) + ". [" + date + "] Order #" + str(order_id) + " — ₹" + str(round(total, 2)) + " — Items: " + items_str)
    order_num = order_num + 1
    k = k + 1